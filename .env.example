# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=https://your-frontend.vercel.app

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/haven

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_strong_random_secret
JWT_REFRESH_SECRET=change_this_to_a_different_strong_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Auth performance ─────────────────────────────────────────────────────────
# 10 = ~80ms (recommended). 12 = ~400ms (original, too slow). Never go below 8.
BCRYPT_ROUNDS=10

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@haven.ng
EMAIL_FROM_NAME=Haven

# ─── WhatsApp bot integration ─────────────────────────────────────────────────
# Shared secret — must match INTERNAL_API_KEY in the bot's .env
INTERNAL_API_KEY=generate_with__openssl_rand_hex_32
# URL where the WhatsApp bot's HTTP server is running
BOT_BASE_URL=http://localhost:3000

HAVEN_BOT_WHATSAPP=2349017335663
HAVEN_SUPPORT_WHATSAPP=2349017335663

# ─── Points ───────────────────────────────────────────────────────────────────
POINTS_REDEMPTION_THRESHOLD=5000
POINTS_AIRTIME_VALUE=1000
