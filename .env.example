# ─────────────────────────────────────────────────────────────────────────────
# Haven Backend — Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/haven

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate both with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_random_64_char_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── WhatsApp Bot Integration ──────────────────────────────────────────────────
# CRITICAL: This MUST match INTERNAL_API_KEY in the bot's .env
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=replace_with_random_64_char_hex
BOT_BASE_URL=http://localhost:3000

# WhatsApp numbers (international format without +)
HAVEN_BOT_WHATSAPP=2349017335663
HAVEN_SUPPORT_WHATSAPP=2349017335663

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Paystack (payments) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── VTPass (airtime/data) ─────────────────────────────────────────────────────
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_SECRET_KEY=your_vtpass_secret_key
VTPASS_BASE_URL=https://sandbox.vtpass.com/api

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A: Resend (preferred — no SMTP needed)
RESEND_API_KEY=re_your_resend_api_key

# Option B: SMTP (used if RESEND_API_KEY is not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password

EMAIL_FROM=noreply@haven.ng
EMAIL_FROM_NAME=Haven

# ── bcrypt ────────────────────────────────────────────────────────────────────
# 10 = ~80ms per hash (recommended). Never go below 8 in production.
BCRYPT_ROUNDS=10

# ── Points system ─────────────────────────────────────────────────────────────
POINTS_REDEMPTION_THRESHOLD=5000
POINTS_AIRTIME_VALUE=1000
