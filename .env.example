# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/haven_db

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_32+_char_random_string_here
JWT_REFRESH_SECRET=replace_with_different_32+_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Cloudinary (for image/video uploads) ─────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Paystack (Nigerian payment gateway) ─────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── VTPass (Airtime redemption) ─────────────────────
# Get from: https://vtpass.com/documentation
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_SECRET_KEY=your_vtpass_secret_key
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
# For production: https://vtpass.com/api

# ─── Email (Resend - recommended) ────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Haven

# Alternative: SMTP (Nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# ─── Haven WhatsApp ───────────────────────────────────
HAVEN_BOT_WHATSAPP=2349017335663
HAVEN_SUPPORT_WHATSAPP=2349017335663

# ─── Points Config ───────────────────────────────────
POINTS_REDEMPTION_THRESHOLD=5000
POINTS_AIRTIME_VALUE=1000
