generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UrgencyLevel {
  STANDARD
  URGENT
  EMERGENCY
}

enum ServiceRequestStatus {
  PENDING
  QUOTED
  BOOKED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING_PAYMENT
  PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum InquiryStatus {
  NEW
  REPLIED
  CLOSED
}

enum HousingCategory {
  HOSTEL
  LODGE
  APARTMENT
  SQUAT
}

enum PointsTransactionType {
  EARNED
  REDEEMED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer Customer?
  provider Provider?

  @@index([email])
  @@index([role, isActive])
}

model Customer {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  avatarUrl   String?
  totalPoints Int      @default(0)
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings           Booking[]
  reviews            Review[]
  inquiries          Inquiry[]
  serviceRequests    ServiceRequest[]
  pointsTransactions PointsTransaction[]

  @@index([phone])
  @@index([userId])
}

model Provider {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  ownerName    String
  phone        String
  category     String
  location     String
  description  String
  services     String?
  experience   String?
  website      String?
  isVerified   Boolean  @default(false)
  isPublished  Boolean  @default(true)
  avgRating    Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews Int      @default(0)
  profileViews Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolioImages PortfolioImage[]
  bookings        Booking[]
  reviews         Review[]
  inquiries       Inquiry[]

  @@index([phone])
  @@index([category, isPublished])
  @@index([location])
  @@index([avgRating])
}

model PortfolioImage {
  id         String   @id @default(uuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  imageUrl   String
  publicId   String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([providerId])
}

model HousingListing {
  id             String          @id @default(uuid())
  ownerId        String
  title          String
  category       HousingCategory
  description    String
  location       String
  address        String?
  pricePerMonth  Decimal?        @db.Decimal(12, 2)
  imageUrl       String?
  phone          String
  avgRating      Decimal         @default(0) @db.Decimal(3, 2)
  totalReviews   Int             @default(0)
  isAvailable    Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([isAvailable, category])
  @@index([location])
}

model ServiceRequest {
  id            String               @id @default(uuid())
  customerId    String
  customer      Customer             @relation(fields: [customerId], references: [id])
  category      String
  description   String
  address       String
  preferredDate DateTime
  preferredTime String
  urgency       UrgencyLevel         @default(STANDARD)
  status        ServiceRequestStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  media    ServiceRequestMedia[]
  bookings Booking[]

  @@index([customerId, status])
  @@index([status])
}

model ServiceRequestMedia {
  id               String         @id @default(uuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  mediaUrl         String
  publicId         String
  mediaType        String
  createdAt        DateTime       @default(now())

  @@index([serviceRequestId])
}

model Booking {
  id               String        @id @default(uuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id])
  providerId       String
  provider         Provider       @relation(fields: [providerId], references: [id])
  amount           Decimal        @db.Decimal(12, 2)
  status           BookingStatus  @default(PENDING_PAYMENT)
  scheduledAt      DateTime
  completedAt      DateTime?
  pointsAwarded    Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  payment Payment?
  review  Review?

  @@index([customerId, status])
  @@index([providerId, status])
  @@index([serviceRequestId])
  @@index([status])
}

model Payment {
  id               String        @id @default(uuid())
  bookingId        String        @unique
  booking          Booking       @relation(fields: [bookingId], references: [id])
  customerId       String
  amount           Decimal       @db.Decimal(12, 2)
  gateway          String        @default("paystack")
  gatewayReference String        @unique
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([customerId])
  @@index([gatewayReference])
}

model Review {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id])
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id])
  rating        Int
  comment       String?
  providerReply String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([providerId])
  @@index([customerId])
}

model Inquiry {
  id         String        @id @default(uuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  providerId String
  provider   Provider      @relation(fields: [providerId], references: [id])
  service    String
  message    String
  reply      String?
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([providerId, status])
  @@index([customerId])
}

model PointsTransaction {
  id          String                @id @default(uuid())
  customerId  String
  customer    Customer              @relation(fields: [customerId], references: [id])
  type        PointsTransactionType
  amount      Int
  bookingId   String?
  description String
  createdAt   DateTime              @default(now())

  @@index([customerId])
}

// ─── Bot session store ────────────────────────────────────────────────────────
// Replaces the WhatsApp bot's in-memory Map so sessions survive restarts.
model BotSession {
  phoneNumber  String   @id
  messages     Json     @default("[]")
  preferences  Json     @default("{}")
  resolvedRole String?  // CUSTOMER | PROVIDER | ADMIN | null (unknown)
  profileId    String?  // Cached Customer.id or Provider.id
  userId       String?  // Cached User.id
  updatedAt    DateTime @updatedAt

  @@index([phoneNumber])
}
